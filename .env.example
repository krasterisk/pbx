# =============================================================================
# Krasterisk v4 вЂ” Environment Variables Template
# Copy to .env and fill in your values
# =============================================================================

# --- Database (MySQL) --------------------------------------------------------
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=krasterisk
DB_PASSWORD=your_db_password
DB_NAME=krasterisk

# --- JWT Authentication -------------------------------------------------------
JWT_SECRET=change_me_to_random_string_min_32_chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change_me_to_another_random_string
JWT_REFRESH_EXPIRES_IN=30d

# --- AMI (Asterisk Manager Interface) ----------------------------------------
# Must match manager.conf on your Asterisk server
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_LOGIN=krasterisk
AMI_SECRET=your_ami_secret

# --- ARI (Asterisk REST Interface) -------------------------------------------
ARI_HOST=127.0.0.1
ARI_PORT=8088
ARI_USER=krasterisk
ARI_PASSWORD=your_ari_password
ARI_PROTOCOL=http

# --- RTP / Media --------------------------------------------------------------
EXTERNAL_RTP_HOST=your_public_ip
RTP_MIN_PORT=20000
RTP_MAX_PORT=20100

# --- Server -------------------------------------------------------------------
BACKEND_PORT=5010
FRONTEND_PORT=3010
DEFAULT_VPBX_USER_UID=0

# --- Redis (optional) ---------------------------------------------------------
# Used by BullMQ for persistent webhook delivery queues with retry on restart.
# If REDIS_HOST is not set, falls back to in-memory setTimeout retry (3 attempts).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Dialplan -> Backend integration ------------------------------------------
# URL of this backend as seen FROM the Asterisk server (used inside CURL() in dialplan).
# Same host:    http://127.0.0.1:5010/api
# Remote host:  https://pbx-backend.example.com/api
# вљ пёЏ  Must be reachable from Asterisk server, NOT from browser.
DIALPLAN_BACKEND_URL=http://127.0.0.1:5010/api

# API key for internal Asterisk->Backend CURL requests.
# Set any random string, leave empty to disable key validation.
DIALPLAN_API_KEY=

# HMAC-SHA256 secret for signing outbound webhook payloads.
# External CRM/Analytics systems verify the X-Krasterisk-Signature header.
# Leave empty to disable signing (not recommended for production).
WEBHOOK_SECRET=

# --- Call Recordings ----------------------------------------------------------
# Absolute path on the Asterisk server where MixMonitor writes WAV files
# and ffmpeg produces MP3 files.
RECORDS_BASE_PATH=/usr/records

# Public base URL for generating MP3 download links sent in on_hangup webhook payloads.
# Customers/CRM systems receive this URL to download the recording.
# Example: https://pbx.example.com/records
RECORDS_BASE_URL=https://your-domain.com/records

# --- Mailer (SMTP) ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=your_smtp_password

# --- Telegram Notifications ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SMS (Beeline) ------------------------------------------------------------
SMS_BEELINE_TOKEN=

# --- Deployment Mode ----------------------------------------------------------
# BOX = local docker install (all modules open, no SuperAdmin panel)
# CLOUD = multi-tenant SaaS (default)
# OPENSOURCE = open-source mode (no Marketplace, no tenant_modules)
DEPLOYMENT_MODE=CLOUD
APP_VERSION=4.0.0
APP_URL=https://pbx.example.com

# --- Bank Webhook (alfawebhook integration) -----------------------------------
BANK_WEBHOOK_SECRET=change-me-strong-secret

# --- SBIS Accounting Integration (accounting.provider=sbis) ------------------
SBIS_LOGIN=your-sbis-login
SBIS_PASS=your-sbis-password
SBIS_ACC=your-sbis-account-name
SBIS_PBX_SUBJECT_CODE=26
SBIS_PBX_SUBJECT=Услуги облачной телефонии KrAsterisk

# --- Billing Reminder (overrides cloud_settings) -----------------------------
# Reminder emails are sent N days before estimated balance depletion
# Configure via UI: Settings > Реквизиты > Бухгалтерская интеграция
BILLING_REMINDER_DAYS=10,7,5,3,2,1

# --- AI Chat (aiPBX integration) --------------------------------------------
# aiPBX server URL and API key (create via POST /api/api-keys)
AIPBX_URL=https://your-aipbx.com/api
AIPBX_TOKEN=aipbx_xxxxxxxxxxxx
AIPBX_CHAT_ID=1

# MCP multi-tenancy: KrAsterisk public URL for aiPBX to call back
# aiPBX will POST to {KRASTERISK_PUBLIC_URL}/api/mcp with these credentials
KRASTERISK_PUBLIC_URL=https://your-krasterisk-domain.com
KRASTERISK_SERVICE_TOKEN=change_me_strong_secret_min_32_chars
